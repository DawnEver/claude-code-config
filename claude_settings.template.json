{
  "env": {
    "CLAUDE_CODE_FORK_SUBAGENT": "1",
    "CLAUDE_AUTO_BACKGROUND_TASKS": "1",
    "ENABLE_LSP_TOOLS": "1",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_FEEDBACK_COMMAND": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEYS": "1",
    "DISABLE_LOGIN_COMMAND": "1",
    "DISABLE_LOGOUT_COMMAND": "1",
    "ANTHROPIC_BASE_URL": "https://api.deepseek.com/anthropic",
    "ANTHROPIC_AUTH_TOKEN": "your-api-key-here",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "deepseek-v4-flash",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "deepseek-v4-flash",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "deepseek-v4-pro"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(openspec *)",
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(make *)",
      "Bash(ln *)",
      "Bash(node *)",
      "Skill(update-config)",
      "Bash(chmod +x *)",
      "Bash(echo \"exit: $?\")",
      "Bash(cmd *)",
      "Bash(powershell *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(curl * | bash)"
    ],
    "defaultMode": "acceptEdits"
  },
  "model": "haiku",
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/scripts/notify.js --show-native false"
          }
        ]
      }
    ]
  },
  "worktree": {
    "baseRef": "fresh"
  },
  "statusLine": {
    "type": "command",
    "command": "node ~/.claude/scripts/launch_claude_hud.js"
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "claude-hud@claude-hud": true,
    "superpowers@superpowers-marketplace": false,
    "codex@openai-codex": true,
    "ralph-loop@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    },
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "effortLevel": "low",
  "autoUpdatesChannel": "latest",
  "minimumVersion": "2.1.119",
  "tui": "fullscreen",
  "theme": "auto",
  "editorMode": "normal",
  "verbose": true,
  "preferredNotifChannel": "auto",
  "terminalProgressBarEnabled": true,
  "skipAutoPermissionPrompt": true,
  "autoMode": {
    "environment": [
      "$defaults"
    ]
  },
  "metadata": {
    "NOTIFY_WAITING_TIMEOUT_MINUTES": 5
  },
  "mcpServers": {
    "openspec": {
      "command": "npx",
      "args": [
        "-y",
        "@fission-ai/openspec-mcp"
      ]
    }
  }
}
