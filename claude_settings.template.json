{
  "env": {
    "CLAUDE_CODE_FORK_SUBAGENT": "1",
    "CLAUDE_CODE_WORKFLOWS": "1",
    "CLAUDE_CODE_USE_POWERSHELL_TOOL": "1",
    "CLAUDE_CODE_ENABLE_AUTO_MODE": "1",
    "CLAUDE_AUTO_BACKGROUND_TASKS": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_LSP_TOOLS": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_FEEDBACK_COMMAND": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEYS": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(openspec *)",
      "Bash(git *)",
      "Bash(make *)",
      "Bash(ln *)",
      "Bash(node *)",
      "Skill(update-config)",
      "Bash(chmod +x *)",
      "Bash(echo \"exit: $?\")",
      "Bash(cmd *)",
      "Bash(powershell *)",
      "mcp__claude-in-chrome__tabs_context_mcp",
      "mcp__ide__getDiagnostics",
      "Bash(pwsh --version)",
      "Bash(mshta *)",
      "Bash(npm init *)",
      "Bash(npm i *)",
      "Bash(python *)",
      "Bash(cmd.exe *)",
      "Bash(npx tsc *)",
      "Bash(npm run *)",
      "WebSearch",
      "PowerShell(git *)",
      "Bash(findstr submodule *)",
      "mcp__ide__executeCode",
      "PowerShell(Test-Path *)",
      "PowerShell(Add-Content *)",
      "Bash(Code.exe)",
      "Bash(goto)",
      "Bash(Remove-Item *)",
      "PowerShell(Get-Item *)",
      "PowerShell(Get-ChildItem *)",
      "PowerShell(code *)",
      "Skill(codex:rescue)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(curl * | bash)"
    ],
    "defaultMode": "auto"
  },
  "model": "opusplan",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/scripts/setup/fix-lsp-windows.js",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/scripts/hooks/notify-hook.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/scripts/hooks/sharp-review-hook.js",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "worktree": {
    "baseRef": "fresh"
  },
  "statusLine": {
    "type": "command",
    "command": "node ~/.claude/scripts/hooks/hud-hook.js"
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "claude-hud@claude-hud": true,
    "codex@openai-codex": true,
    "takeover@cc-market": true,
    "typescript-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": false,
    "rem@cc-market": true
  },
  "extraKnownMarketplaces": {
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      },
      "autoUpdate": true
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      },
      "autoUpdate": true
    },
    "cc-market": {
      "source": {
        "source": "github",
        "repo": "DawnEver/cc-market"
      },
      "autoUpdate": true
    }
  },
  "effortLevel": "low",
  "tui": "fullscreen",
  "skipWorkflowUsageWarning": true,
  "theme": "auto",
  "editorMode": "normal",
  "verbose": true,
  "preferredNotifChannel": "auto",
  "autoCompactEnabled": true,
  "terminalProgressBarEnabled": true,
  "teammateMode": "auto",
  "remoteControlAtStartup": true,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "autoMode": {
    "environment": [
      "$defaults"
    ]
  },
  "metadata": {
    "NOTIFY_WAITING_TIMEOUT_MINUTES": 1
  }
}
