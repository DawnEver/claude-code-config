{
  "name": "claude-notifications",
  "displayName": "Claude Notifications",
  "description": "Show Claude Code hook notifications inside VS Code and provide jump actions.",
  "version": "0.0.2",
  "publisher": "DawnEver",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.117.0"
  },
  "categories": [
    "Notifications",
    "Other"
  ],
  "keywords": [
    "claude",
    "claude code",
    "notifications",
    "toast",
    "native notifications",
    "hooks"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/DawnEver/claude-code-config.git"
  },
  "bugs": {
    "url": "https://github.com/DawnEver/claude-code-config/issues"
  },
  "homepage": "https://github.com/DawnEver/claude-code-config",
  "license": "MIT",
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Claude Notifications",
      "properties": {
        "claudeNotifications.logPath": {
          "type": "string",
          "default": "${userHome}/.claude/logs/notifications.jsonl",
          "description": "Path to the JSONL log written by scripts/notify.js"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p . && npm run fix",
    "watch": "tsc -watch -p .",
    "format": "prettier --check \"src/**/*.ts\"",
    "fix": "prettier --write \"src/**/*.ts\"",
    "package": "vsce package -o dist/",
    "test": "claude --bare --model haiku \"please read ~/.claude/settings.json to test claude permission system [Expected waiting for user's input]\""
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/vscode": "^1.117.0",
    "@vscode/vsce": "^3.9.1",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  },
  "author": "DawnEver",
  "type": "commonjs"
}
