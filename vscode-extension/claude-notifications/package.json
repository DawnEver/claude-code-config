{

  "name": "claude-notifications-vscode",
  "displayName": "Claude Notifications for VS Code",
  "description": "Claude Code hook notifications inside VS Code and terminal focus.",
  "version": "0.0.4",
  "publisher": "MingyangBao",
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DawnEver/claude-code-config"
  },
  "bugs": {
    "url": "https://github.com/DawnEver/claude-code-config/issues"
  },
  "homepage": "https://github.com/DawnEver/claude-code-config#readme",
  "galleryBanner": {
    "color": "#1a1a1a",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.117.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "claude",
    "claude code",
    "notifications",
    "toast",
    "native notifications",
    "hooks"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {},
  "scripts": {
    "compile": "tsc -p . && npm run fix",
    "watch": "tsc -watch -p .",
    "format": "prettier --check \"src/**/*.ts\"",
    "fix": "prettier --write \"src/**/*.ts\"",
    "package": "vsce package -o dist/",
    "test": "claude --bare --model haiku \"please read ~/.claude/settings.json to test claude permission system [Expected waiting for user's input]\""
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/vscode": "^1.117.0",
    "@vscode/vsce": "^3.9.1",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  },
  "author": "MingyangBao",
  "type": "commonjs"
}
