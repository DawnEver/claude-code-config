{
  "name": "claude-notifications",
  "displayName": "Claude Notifications",
  "description": "Show Claude Code hook notifications inside VS Code and provide jump actions.",
  "version": "0.0.1",
  "publisher": "DawnEver",
  "icon": "icon.ico",
  "engines": {
    "vscode": "^1.117.0"
  },
  "categories": [
    "Notifications",
    "Other"
  ],
  "keywords": [
    "claude",
    "claude code",
    "notifications",
    "toast",
    "native notifications",
    "hooks"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/DawnEver/claude-code-config.git"
  },
  "bugs": {
    "url": "https://github.com/DawnEver/claude-code-config/issues"
  },
  "homepage": "https://github.com/DawnEver/claude-code-config",
  "license": "MIT",
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeNotifications.showOutput",
        "title": "Claude Notifications: Show Output"
      },
      {
        "command": "claudeNotifications.jumpToRecent",
        "title": "Claude Notifications: Jump to Recent Event"
      },
      {
        "command": "claudeNotifications.clearHistory",
        "title": "Claude Notifications: Clear History"
      }
    ],
    "configuration": {
      "title": "Claude Notifications",
      "properties": {
        "claudeNotifications.logPath": {
          "type": "string",
          "default": "${userHome}/.claude/logs/notifications.jsonl",
          "description": "Path to the JSONL log written by scripts/notify.js"
        },
        "claudeNotifications.maxEvents": {
          "type": "number",
          "default": 500,
          "minimum": 10,
          "maximum": 5000,
          "description": "How many recent events to keep in memory for quick-pick."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p . && npm run fix",
    "watch": "tsc -watch -p .",
    "format": "prettier --check \"src/**/*.ts\"",
    "fix": "prettier --write \"src/**/*.ts\"",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/vscode": "^1.117.0",
    "@vscode/vsce": "^3.9.1",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  },
  "author": "DawnEver",
  "type": "commonjs"
}
